// Ved Logistics — Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  phone         String   @default("")
  department    String   @default("General")
  role          String   @default("employee") // admin | employee
  employeeRole  String   @default("normal")   // normal | rider | admin
  baseSalary    Float    @default(0)
  joinDate      String   @default("")
  status        String   @default("active")   // active | inactive
  avatar        String   @default("")
  bikeNumber    String   @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attendance     Attendance[]
  rides          Ride[]
  dailyLogs      DailyLog[]
  advances       Advance[]
  expenses       Expense[]
  salaryPayments SalaryPayment[]
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  date       String
  checkIn    DateTime
  checkOut   DateTime?
  location   String   @default("Office")
  note       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
}

// Daily work log — simple counts per employee per day
model DailyLog {
  id         String   @id @default(cuid())
  employeeId String
  date       String
  delivered  Int      @default(0)   // items delivered today
  pickedUp   Int      @default(0)   // items picked up today
  store      Int      @default(0)   // items in store/warehouse
  note       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Ride tracking with speedometer photo proof
model Ride {
  id         String   @id @default(cuid())
  riderId    String
  date       String
  startKm    Int
  endKm      Int      @default(0)
  distance   Int      @default(0)
  startPhoto String?  // base64 or URL of speedometer at start
  endPhoto   String?  // base64 or URL of speedometer at end
  fuelCost   Float    @default(0)
  status     String   @default("started") // started | completed
  note       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rider Employee @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([date])
}

// Salary advance requests
model Advance {
  id           String   @id @default(cuid())
  employeeId   String
  amount       Float
  reason       String   @default("")
  status       String   @default("pending") // pending | approved | rejected
  requestDate  DateTime @default(now())
  approvedDate DateTime?
  approvedBy   String   @default("")
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Expense {
  id           String   @id @default(cuid())
  employeeId   String
  type         String   @default("fuel")
  amount       Float
  description  String   @default("")
  receiptImage String?
  status       String   @default("pending") // pending | approved | rejected
  requestDate  DateTime @default(now())
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model SalaryPayment {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  deductions  Float    @default(0)  // total advance deductions
  netAmount   Float    @default(0)  // amount after deductions
  paymentDate String
  month       String
  note        String   @default("")
  paidBy      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([month])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
